<Application x:Class="TakingMedications.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Startup="App_Startup">
    <Application.Resources>

        <!-- ── Цветовая палитра (тёмная тема, единая с прежним проектом) ── -->
        <SolidColorBrush x:Key="AccentBrush" Color="#6C63FF" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#5A52D5" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#2ECC71" />
        <SolidColorBrush x:Key="WarningBrush" Color="#E67E22" />
        <SolidColorBrush x:Key="DangerBrush" Color="#E74C3C" />
        <SolidColorBrush x:Key="BgDarkBrush" Color="#1A1A2E" />
        <SolidColorBrush x:Key="BgCardBrush" Color="#16213E" />
        <SolidColorBrush x:Key="BgInputBrush" Color="#0F3460" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#EAEAEA" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A0A0B8" />
        <SolidColorBrush x:Key="SectionMorningBrush" Color="#F1C40F" />
        <SolidColorBrush x:Key="SectionDayBrush"     Color="#3498DB" />
        <SolidColorBrush x:Key="SectionEveningBrush" Color="#9B59B6" />
        <SolidColorBrush x:Key="SectionNightBrush"   Color="#34495E" />
        <SolidColorBrush x:Key="SectionSosBrush"     Color="#E74C3C" />
        <SolidColorBrush x:Key="CourseBrush"         Color="#FFD54F" />
        <SolidColorBrush x:Key="SeparatorBrush"      Color="#00FFFFFF" />
        <SolidColorBrush x:Key="CardBorderBrush"     Color="#00FFFFFF" />

        <!-- ── Закруглённая кнопка ── -->
        <Style x:Key="RoundButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Маленькая (icon) кнопка -->
        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource RoundButton}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="MinWidth" Value="32" />
        </Style>

        <!-- ── Тёмный TextBox ── -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource BgInputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="DarkLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

    </Application.Resources>
</Application>
