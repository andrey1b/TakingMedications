<Window x:Class="TakingMedications.Views.DocumentsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Документы"
        Width="680" Height="560" MinWidth="480" MinHeight="400"
        Background="{DynamicResource BgDarkBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок + кнопки -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="HeaderLabel"
                       FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="BtnAddFile"
                        Style="{StaticResource RoundButton}"
                        Background="{StaticResource SuccessBrush}"
                        Margin="0,0,8,0"
                        Click="BtnAddFile_Click"/>
                <Button x:Name="BtnOpenFolder"
                        Style="{StaticResource RoundButton}"
                        Background="{DynamicResource AccentBrush}"
                        Margin="0,0,8,0"
                        Click="BtnOpenFolder_Click"/>
                <Button x:Name="BtnRefresh"
                        Style="{StaticResource RoundButton}"
                        Background="{StaticResource WarningBrush}"
                        Click="BtnRefresh_Click"/>
            </StackPanel>
        </Grid>

        <!-- Список файлов -->
        <Border Grid.Row="1"
                Background="{DynamicResource BgCardBrush}"
                CornerRadius="12" Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="FilesList"/>
            </ScrollViewer>
        </Border>

        <!-- Кнопка закрыть -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnClose"
                    Style="{StaticResource RoundButton}"
                    Background="{DynamicResource AccentBrush}"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
