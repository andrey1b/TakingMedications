<Window x:Class="TakingMedications.Views.PurchaseEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Покупка"
        Width="460" Height="360"
        Background="{DynamicResource BgDarkBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="18,14,18,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="HeaderLabel"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,12" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" x:Name="LblDate"
                       Style="{StaticResource DarkLabel}"
                       VerticalAlignment="Center" Margin="0,8,8,0" />
            <DatePicker Grid.Row="0" Grid.Column="1" x:Name="DatePickerCtl"
                        Margin="0,8,0,0" />

            <TextBlock Grid.Row="1" Grid.Column="0" x:Name="LblMed"
                       Style="{StaticResource DarkLabel}"
                       VerticalAlignment="Center" Margin="0,8,8,0" />
            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="MedCombo"
                      DisplayMemberPath="Name" SelectedValuePath="Id"
                      Margin="0,8,0,0" />

            <TextBlock Grid.Row="2" Grid.Column="0" x:Name="LblAmount"
                       Style="{StaticResource DarkLabel}"
                       VerticalAlignment="Center" Margin="0,8,8,0" />
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="AmountBox"
                     Style="{StaticResource DarkTextBox}"
                     HorizontalContentAlignment="Right"
                     Margin="0,8,0,0" />

            <TextBlock Grid.Row="3" Grid.Column="0" x:Name="LblNote"
                       Style="{StaticResource DarkLabel}"
                       VerticalAlignment="Center" Margin="0,8,8,0" />
            <TextBox Grid.Row="3" Grid.Column="1" x:Name="NoteBox"
                     Style="{StaticResource DarkTextBox}"
                     Margin="0,8,0,0" />
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BtnCancel" Style="{StaticResource RoundButton}"
                    Background="{StaticResource DangerBrush}"
                    Margin="0,0,8,0"
                    Click="BtnCancel_Click" />
            <Button x:Name="BtnSave" Style="{StaticResource RoundButton}"
                    Background="{StaticResource SuccessBrush}"
                    Click="BtnSave_Click" />
        </StackPanel>
    </Grid>
</Window>
