<Window x:Class="TakingMedications.Views.InteractionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Взаимодействия лекарств"
        Width="780" Height="560"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgMainBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock x:Name="HeaderLabel" Grid.Row="0"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,8"/>

        <!-- Дисклеймер -->
        <Border Grid.Row="1"
                Background="#FFEBEE" BorderBrush="#C62828" BorderThickness="1"
                CornerRadius="6" Padding="10,6" Margin="0,0,0,10">
            <TextBlock x:Name="DisclaimerLabel"
                       TextWrapping="Wrap" FontSize="11"
                       Foreground="#B71C1C"/>
        </Border>

        <!-- Сводка -->
        <TextBlock x:Name="SummaryLabel" Grid.Row="2"
                   FontSize="12"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,0,0,8"/>

        <!-- Список взаимодействий -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="InteractionsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,6"
                                Background="{DynamicResource BgCardBrush}"
                                CornerRadius="8" Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Серьёзность -->
                                <Border Grid.Column="0"
                                        Background="{Binding SeverityBg}"
                                        CornerRadius="5" Padding="6,3"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top" Margin="0,2,8,0">
                                    <TextBlock Text="{Binding SeverityLabel}"
                                               Foreground="White"
                                               FontSize="11" FontWeight="Bold"/>
                                </Border>

                                <!-- Пара + примечание -->
                                <StackPanel Grid.Column="1">
                                    <TextBlock FontSize="13" FontWeight="Bold"
                                               Foreground="{DynamicResource TextPrimaryBrush}">
                                        <Run Text="{Binding NameA, Mode=OneTime}"/>
                                        <Run Text=" ⇄ "/>
                                        <Run Text="{Binding NameB, Mode=OneTime}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Note, Mode=OneTime}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Нет взаимодействий -->
        <TextBlock x:Name="NoHitsLabel" Grid.Row="3"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="14"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Visibility="Collapsed"/>

        <!-- Кнопка закрыть -->
        <Button x:Name="BtnClose" Grid.Row="4"
                HorizontalAlignment="Right"
                Margin="0,12,0,0"
                Padding="20,7"
                Style="{DynamicResource RoundButton}"
                Click="BtnClose_Click"/>
    </Grid>
</Window>
