<Window x:Class="TakingMedications.Views.PressureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Артериальное давление"
        Width="720" Height="680" MinWidth="580" MinHeight="500"
        Background="{DynamicResource BgDarkBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,3,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8,8,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18,14,18,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" x:Name="HeaderLabel"
                   FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,10"/>

        <!-- Ввод -->
        <Border Grid.Row="1"
                Background="{DynamicResource BgCardBrush}"
                CornerRadius="12" Padding="14,10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" x:Name="LblPulse"
                           Style="{StaticResource DarkLabel}" Margin="0,0,16,3"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="LblSys"
                           Style="{StaticResource DarkLabel}" Margin="0,0,12,3"/>
                <TextBlock Grid.Row="0" Grid.Column="2" x:Name="LblDia"
                           Style="{StaticResource DarkLabel}" Margin="0,0,12,3"/>
                <TextBlock Grid.Row="0" Grid.Column="3" x:Name="LblSugar"
                           Style="{StaticResource DarkLabel}" Margin="0,0,12,3"/>

                <TextBox Grid.Row="1" Grid.Column="0" x:Name="PulseBox"
                         Style="{StaticResource DarkTextBox}"
                         Width="80" HorizontalAlignment="Left"
                         HorizontalContentAlignment="Center" Margin="0,0,16,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="SysBox"
                         Style="{StaticResource DarkTextBox}"
                         Width="80" HorizontalAlignment="Left"
                         HorizontalContentAlignment="Center" Margin="0,0,12,0"/>
                <TextBox Grid.Row="1" Grid.Column="2" x:Name="DiaBox"
                         Style="{StaticResource DarkTextBox}"
                         Width="80" HorizontalAlignment="Left"
                         HorizontalContentAlignment="Center" Margin="0,0,12,0"/>
                <TextBox Grid.Row="1" Grid.Column="3" x:Name="SugarBox"
                         Style="{StaticResource DarkTextBox}"
                         Width="80" HorizontalAlignment="Left"
                         HorizontalContentAlignment="Center" Margin="0,0,12,0"/>
                <Button Grid.Row="1" Grid.Column="4" x:Name="BtnSave"
                        Style="{StaticResource RoundButton}"
                        Background="{StaticResource SuccessBrush}"
                        HorizontalAlignment="Right"
                        Click="BtnSave_Click"/>
            </Grid>
        </Border>

        <!-- Вкладки -->
        <TabControl Grid.Row="2" x:Name="MainTabs"
                    SelectionChanged="MainTabs_SelectionChanged">

            <!-- История -->
            <TabItem x:Name="TabHistory">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource BgCardBrush}"
                            CornerRadius="0,12,12,12" Padding="6,6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="HistoryPanel"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Легенда + кнопка удаления -->
                    <Grid Grid.Row="1" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <WrapPanel Grid.Column="0" VerticalAlignment="Center" Margin="2,0,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                <Rectangle Width="10" Height="10" Fill="#2ECC71"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock x:Name="LblLegOptimal" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                <Rectangle Width="10" Height="10" Fill="#27AE60"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock x:Name="LblLegNormal" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                <Rectangle Width="10" Height="10" Fill="#F1C40F"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock x:Name="LblLegHighNormal" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                <Rectangle Width="10" Height="10" Fill="#E67E22"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock x:Name="LblLegStage1" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="10" Height="10" Fill="#E74C3C"
                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock x:Name="LblLegStage2" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </WrapPanel>

                        <Button Grid.Column="1" x:Name="BtnDelete"
                                Style="{StaticResource RoundButton}"
                                Background="{StaticResource DangerBrush}"
                                IsEnabled="False"
                                Click="BtnDelete_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- График -->
            <TabItem x:Name="TabChart">
                <Border Background="{DynamicResource BgCardBrush}"
                        CornerRadius="0,12,12,12" Padding="8">
                    <Canvas x:Name="ChartCanvas" Background="Transparent"
                            SizeChanged="ChartCanvas_SizeChanged"/>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Кнопка закрыть -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnClose"
                    Style="{StaticResource RoundButton}"
                    Background="{DynamicResource AccentBrush}"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
