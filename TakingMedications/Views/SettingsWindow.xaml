<Window x:Class="TakingMedications.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки"
        Width="520" Height="640" MinWidth="480" MinHeight="520"
        Background="{DynamicResource BgDarkBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="DarkRadioButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Margin" Value="0,3,16,3" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="16" Height="16" Margin="0,0,8,0"
                                  VerticalAlignment="Center">
                                <Ellipse x:Name="Ring"
                                         Stroke="{DynamicResource TextSecondaryBrush}"
                                         StrokeThickness="2"
                                         Fill="Transparent" />
                                <Ellipse x:Name="Dot"
                                         Width="8" Height="8"
                                         Fill="{DynamicResource AccentBrush}"
                                         Visibility="Collapsed" />
                            </Grid>
                            <ContentPresenter VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Dot" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Ring" Property="Stroke"
                                        Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Ring" Property="Stroke"
                                        Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16,14,16,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderLabel"
                   Grid.Row="0"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,12" />

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- ── Язык ── -->
                <Border Background="{DynamicResource BgCardBrush}"
                        CornerRadius="10" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock x:Name="LblLangSection"
                                   Style="{StaticResource SectionHeader}" />
                        <WrapPanel Margin="0,2,0,4">
                            <RadioButton x:Name="RbRu" Content="Русский"
                                         GroupName="Lang"
                                         Style="{StaticResource DarkRadioButton}"
                                         Tag="ru"
                                         Checked="LangRadio_Checked" />
                            <RadioButton x:Name="RbUk" Content="Українська"
                                         GroupName="Lang"
                                         Style="{StaticResource DarkRadioButton}"
                                         Tag="uk"
                                         Checked="LangRadio_Checked" />
                            <RadioButton x:Name="RbEn" Content="English"
                                         GroupName="Lang"
                                         Style="{StaticResource DarkRadioButton}"
                                         Tag="en"
                                         Checked="LangRadio_Checked" />
                            <RadioButton x:Name="RbEs" Content="Español"
                                         GroupName="Lang"
                                         Style="{StaticResource DarkRadioButton}"
                                         Tag="es"
                                         Checked="LangRadio_Checked" />
                            <RadioButton x:Name="RbDe" Content="Deutsch"
                                         GroupName="Lang"
                                         Style="{StaticResource DarkRadioButton}"
                                         Tag="de"
                                         Checked="LangRadio_Checked" />
                            <RadioButton x:Name="RbFr" Content="Français"
                                         GroupName="Lang"
                                         Style="{StaticResource DarkRadioButton}"
                                         Tag="fr"
                                         Checked="LangRadio_Checked" />
                            <RadioButton x:Name="RbIt" Content="Italiano"
                                         GroupName="Lang"
                                         Style="{StaticResource DarkRadioButton}"
                                         Tag="it"
                                         Checked="LangRadio_Checked" />
                        </WrapPanel>
                        <TextBlock x:Name="LangNote"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- ── Тема ── -->
                <Border Background="{DynamicResource BgCardBrush}"
                        CornerRadius="10" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock x:Name="LblThemeSection"
                                   Style="{StaticResource SectionHeader}"/>
                        <WrapPanel Margin="0,2,0,0">
                            <RadioButton x:Name="RbThemeDark"
                                         GroupName="Theme"
                                         Style="{StaticResource DarkRadioButton}"
                                         Tag="dark"
                                         Checked="ThemeRadio_Checked"/>
                            <RadioButton x:Name="RbThemeLight"
                                         GroupName="Theme"
                                         Style="{StaticResource DarkRadioButton}"
                                         Tag="light"
                                         Checked="ThemeRadio_Checked"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- ── Пациент ── -->
                <Border Background="{DynamicResource BgCardBrush}"
                        CornerRadius="10" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock x:Name="LblPatientSection"
                                   Style="{StaticResource SectionHeader}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="145" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="LblFio"
                                       Grid.Row="0" Grid.Column="0"
                                       Style="{StaticResource DarkLabel}"
                                       VerticalAlignment="Center"
                                       Margin="0,4,8,4" />
                            <TextBox x:Name="PatientBox"
                                     Grid.Row="0" Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     Margin="0,4,0,4" />

                            <TextBlock x:Name="LblDob"
                                       Grid.Row="1" Grid.Column="0"
                                       Style="{StaticResource DarkLabel}"
                                       VerticalAlignment="Center"
                                       Margin="0,4,8,4" />
                            <TextBox x:Name="DobBox"
                                     Grid.Row="1" Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     Margin="0,4,0,4" />

                            <TextBlock x:Name="LblGender"
                                       Grid.Row="2" Grid.Column="0"
                                       Style="{StaticResource DarkLabel}"
                                       VerticalAlignment="Center"
                                       Margin="0,4,8,4" />
                            <StackPanel Grid.Row="2" Grid.Column="1"
                                        Orientation="Horizontal"
                                        Margin="0,4,0,4">
                                <RadioButton x:Name="RbMale"
                                             GroupName="Gender"
                                             Style="{StaticResource DarkRadioButton}"
                                             Tag="male" />
                                <RadioButton x:Name="RbFemale"
                                             GroupName="Gender"
                                             Style="{StaticResource DarkRadioButton}"
                                             Tag="female" />
                            </StackPanel>
                        </Grid>

                        <Button x:Name="BtnManagePatients"
                                Style="{StaticResource RoundButton}"
                                HorizontalAlignment="Left"
                                Margin="0,10,0,0"
                                Click="BtnManagePatients_Click" />
                    </StackPanel>
                </Border>

                <!-- ── Режим запуска ── -->
                <Border Background="{DynamicResource BgCardBrush}"
                        CornerRadius="10" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock x:Name="LblAppModeSection"
                                   Style="{StaticResource SectionHeader}" />

                        <StackPanel Margin="0,2,0,6">
                            <RadioButton x:Name="RbModeNone"
                                         GroupName="AppMode"
                                         Style="{StaticResource DarkRadioButton}"
                                         Tag="none" />
                            <TextBlock x:Name="LblModeWindowDesc"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="24,1,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,4,0,6">
                            <RadioButton x:Name="RbModeTray"
                                         GroupName="AppMode"
                                         Style="{StaticResource DarkRadioButton}"
                                         Tag="tray" />
                            <TextBlock x:Name="LblModeTrayDesc"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="24,1,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,4,0,6">
                            <RadioButton x:Name="RbModeAutostart"
                                         GroupName="AppMode"
                                         Style="{StaticResource DarkRadioButton}"
                                         Tag="start_with_windows" />
                            <TextBlock x:Name="LblModeAutostartDesc"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="24,1,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,4,0,0">
                            <RadioButton x:Name="RbModeHidden"
                                         GroupName="AppMode"
                                         Style="{StaticResource DarkRadioButton}"
                                         Tag="start_hidden" />
                            <TextBlock x:Name="LblModeHiddenDesc"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="24,1,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Напоминания ── -->
                <Border Background="{DynamicResource BgCardBrush}"
                        CornerRadius="10" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock x:Name="LblRemindersSection"
                                   Style="{StaticResource SectionHeader}"/>

                        <CheckBox x:Name="ChkRemindersVisual"
                                  Style="{StaticResource DarkCheckBox}"
                                  Margin="0,4,0,2"/>
                        <TextBlock x:Name="LblRemindersVisualDesc"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="24,0,0,8"/>

                        <CheckBox x:Name="ChkRemindersVoice"
                                  Style="{StaticResource DarkCheckBox}"
                                  Margin="0,0,0,2"/>
                        <TextBlock x:Name="LblRemindersVoiceDesc"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="24,0,0,6"/>

                        <StackPanel x:Name="VoicePanel"
                                    Orientation="Horizontal"
                                    Margin="24,0,0,0">
                            <TextBlock x:Name="LblVoiceLabel"
                                       Style="{StaticResource DarkLabel}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <ComboBox x:Name="CbVoice"
                                      Width="200"
                                      Background="{DynamicResource BgInputBrush}"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      BorderBrush="{DynamicResource AccentBrush}"
                                      Margin="0,0,8,0"/>
                            <Button x:Name="BtnVoiceTest"
                                    Style="{StaticResource RoundButton}"
                                    Background="{DynamicResource AccentBrush}"
                                    Click="BtnVoiceTest_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Telegram ── -->
                <Border Background="{DynamicResource BgCardBrush}"
                        CornerRadius="10" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock x:Name="LblTgSection"
                                   Style="{StaticResource SectionHeader}"/>

                        <CheckBox x:Name="ChkTgEnable"
                                  Style="{StaticResource DarkCheckBox}"
                                  Margin="0,4,0,2"/>
                        <TextBlock x:Name="LblTgEnableDesc"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="24,0,0,8"/>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="LblTgTokenLabel"
                                       Grid.Column="0"
                                       Style="{StaticResource DarkLabel}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBox x:Name="TgTokenBox"
                                     Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"/>
                            <Button x:Name="BtnTgHow"
                                    Grid.Column="2"
                                    Style="{StaticResource RoundButton}"
                                    Background="{DynamicResource AccentBrush}"
                                    Margin="8,0,0,0"
                                    Click="BtnTgHow_Click"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock x:Name="LblTgStatus"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <WrapPanel>
                            <Button x:Name="BtnTgConnect"
                                    Style="{StaticResource RoundButton}"
                                    Background="{StaticResource SuccessBrush}"
                                    Margin="0,0,6,0"
                                    Click="BtnTgConnect_Click"/>
                            <Button x:Name="BtnTgDisconnect"
                                    Style="{StaticResource RoundButton}"
                                    Background="{StaticResource DangerBrush}"
                                    Margin="0,0,6,0"
                                    Click="BtnTgDisconnect_Click"/>
                            <Button x:Name="BtnTgTest"
                                    Style="{StaticResource RoundButton}"
                                    Background="{DynamicResource AccentBrush}"
                                    Click="BtnTgTest_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- ── Внешний вид ── -->
                <Border Background="{DynamicResource BgCardBrush}"
                        CornerRadius="10" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock x:Name="LblAppearanceSection"
                                   Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,2">
                            <TextBlock x:Name="LblBorderLabel"
                                       Style="{StaticResource DarkLabel}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <RadioButton x:Name="RbBorderLight"
                                         GroupName="Border"
                                         Style="{StaticResource DarkRadioButton}"
                                         Tag="light"/>
                            <RadioButton x:Name="RbBorderMedium"
                                         GroupName="Border"
                                         Style="{StaticResource DarkRadioButton}"
                                         Tag="medium"/>
                            <RadioButton x:Name="RbBorderDark"
                                         GroupName="Border"
                                         Style="{StaticResource DarkRadioButton}"
                                         Tag="dark"/>
                        </StackPanel>
                        <TextBlock x:Name="LblBorderDesc"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="BtnCancel"
                    Style="{StaticResource RoundButton}"
                    Background="{StaticResource DangerBrush}"
                    Margin="0,0,8,0"
                    Click="BtnCancel_Click" />
            <Button x:Name="BtnSave"
                    Style="{StaticResource RoundButton}"
                    Background="{StaticResource SuccessBrush}"
                    Click="BtnSave_Click" />
        </StackPanel>
    </Grid>
</Window>
