<UserControl x:Class="TakingMedications.Views.ScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgDarkBrush}">

    <Grid Margin="0,8,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ Навигация по датам ═══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource BgCardBrush}"
                CornerRadius="12" Padding="14,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="◀" Style="{StaticResource IconButton}"
                        Background="{DynamicResource AccentBrush}"
                        Click="BtnPrevDay_Click" />

                <StackPanel Grid.Column="1" HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="DateLabel"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="DateSubLabel"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <Button Grid.Column="2" Content="▶" Style="{StaticResource IconButton}"
                        Background="{DynamicResource AccentBrush}"
                        Margin="0,0,8,0"
                        Click="BtnNextDay_Click" />
                <Button Grid.Column="3" x:Name="BtnToday"
                        Style="{StaticResource RoundButton}"
                        Background="{DynamicResource AccentBrush}"
                        Margin="0,0,8,0"
                        Click="BtnToday_Click" />
                <Button Grid.Column="4" x:Name="BtnNow"
                        Style="{StaticResource RoundButton}"
                        Background="{DynamicResource AccentBrush}"
                        Click="BtnNow_Click" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="SectionsPanel" />
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="StatsLabel"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="13" Margin="0,0,18,0" />
            <Button x:Name="BtnManage"
                    Style="{StaticResource RoundButton}"
                    Background="{DynamicResource AccentBrush}"
                    Click="BtnManage_Click" />
        </StackPanel>
    </Grid>
</UserControl>
