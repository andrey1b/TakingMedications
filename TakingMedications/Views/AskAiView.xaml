<UserControl x:Class="TakingMedications.Views.AskAiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{DynamicResource TextPrimaryBrush}">
    <UserControl.Resources>
        <!-- Скруглённая кнопка в тон тёмной темы -->
        <Style x:Key="AiBtn" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="8" Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Маленькая «вторичная» кнопка -->
        <Style x:Key="AiBtnSmall" TargetType="Button" BasedOn="{StaticResource AiBtn}">
            <Setter Property="Background" Value="#3A4A5A"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <DockPanel LastChildFill="True">
                <TextBlock x:Name="TbAiQuestionLbl" DockPanel.Dock="Left" VerticalAlignment="Center"
                           FontSize="14" Margin="0,0,8,0"/>
                <Button x:Name="btnAiApiKeys" Style="{StaticResource AiBtnSmall}" DockPanel.Dock="Right" Margin="4,0,0,0"/>
                <Button x:Name="btnAiClear"   Style="{StaticResource AiBtnSmall}" DockPanel.Dock="Right" Margin="4,0,0,0"/>
                <Button x:Name="btnAiSaveAll" Style="{StaticResource AiBtnSmall}" DockPanel.Dock="Right" Margin="4,0,0,0"/>
                <Button x:Name="btnAiAsk"     Style="{StaticResource AiBtn}"      DockPanel.Dock="Right" Margin="4,0,0,0"/>
                <TextBox x:Name="txAiQuestion" FontSize="14" Height="32" VerticalContentAlignment="Center"
                         Background="{DynamicResource BgDarkBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                         CaretBrush="{DynamicResource TextPrimaryBrush}" BorderBrush="#3A4A5A" Padding="6,0"/>
            </DockPanel>
            <WrapPanel Margin="0,8,0,0">
                <TextBlock x:Name="TbAiQuickLbl" VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <Button x:Name="btnAiQuick1" Style="{StaticResource AiBtnSmall}" FontSize="12"/>
                <Button x:Name="btnAiQuick2" Style="{StaticResource AiBtnSmall}" FontSize="12"/>
                <Button x:Name="btnAiQuick3" Style="{StaticResource AiBtnSmall}" FontSize="12"/>
            </WrapPanel>
            <TextBlock x:Name="lblAiStatus" Margin="0,8,0,0" FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="icAiRows">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#2A3A4A" BorderThickness="0,0,0,1" Padding="0,4">
                            <Grid Height="180" Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource AiBtn}" FontSize="15" Height="40"
                                        Margin="0,4,8,0" VerticalAlignment="Top"
                                        Content="{Binding Name}" Background="{Binding HeaderBrush}"
                                        Click="AiOpenButton_Click"/>
                                <TextBox Grid.Column="1" Margin="0,4,8,0"
                                         Text="{Binding Response, UpdateSourceTrigger=PropertyChanged}"
                                         Foreground="{Binding ResponseBrush}" AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" FontSize="12"
                                         Background="{DynamicResource BgDarkBrush}" BorderBrush="#3A4A5A"
                                         CaretBrush="{DynamicResource TextPrimaryBrush}"/>
                                <StackPanel Grid.Column="2" Margin="0,4,0,0">
                                    <CheckBox IsChecked="{Binding Enabled}" Margin="2,2,0,8"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <Button Style="{StaticResource AiBtnSmall}" Content="{Binding CopyLabel}"
                                            FontSize="11" Margin="0,0,0,4" Click="AiCopyButton_Click"/>
                                    <Button Style="{StaticResource AiBtnSmall}" Content="{Binding SaveLabel}"
                                            FontSize="11" Click="AiSaveButton_Click"/>
                                    <TextBlock Text="{Binding Stats}" Margin="2,8,0,0" FontSize="11"
                                               TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
