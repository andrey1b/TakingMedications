<Window x:Class="TakingMedications.Views.ManageMedicationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Список лекарств"
        Width="780" Height="640" MinWidth="600" MinHeight="450"
        Background="{DynamicResource BgDarkBrush}"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="18,14,18,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="HeaderLabel"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,10" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="SectionsPanel" />
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BtnInteractions" Style="{StaticResource RoundButton}"
                    Background="{DynamicResource AccentBrush}"
                    Margin="0,0,8,0"
                    Click="BtnInteractions_Click" />
            <Button x:Name="BtnClose" Style="{StaticResource RoundButton}"
                    Background="{StaticResource DangerBrush}"
                    Click="BtnClose_Click" />
        </StackPanel>
    </Grid>
</Window>
