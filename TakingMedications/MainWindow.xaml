<Window x:Class="TakingMedications.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TakingMedications.Views"
        Title="Приём лекарств"
        Width="900" Height="700" MinWidth="720" MinHeight="500"
        Background="{DynamicResource BgDarkBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Тёмная вкладка TabControl -->
        <Style x:Key="DarkTab" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10,10,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource BgCardBrush}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource TextPrimaryBrush}" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ Шапка в стиле GardenPlanner ═══ -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBgBrush}"
                CornerRadius="12" Padding="16,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleLabel"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource HeaderTextBrush}" />
                    <TextBlock x:Name="SubLabel"
                               FontSize="12"
                               Foreground="{DynamicResource HeaderSubBrush}"
                               Margin="0,2,0,0" />
                    <TextBlock x:Name="UpdateLabel"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#90EE90"
                               Margin="0,3,0,0"
                               Cursor="Hand"
                               Visibility="Collapsed"
                               MouseLeftButtonUp="UpdateLabel_Click" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="BtnExportPdf"
                            Style="{StaticResource IconButton}"
                            Background="{DynamicResource HeaderButtonBrush}"
                            Content="📄" FontSize="18"
                            Margin="0,0,6,0"
                            Click="BtnExportPdf_Click">
                        <Button.ToolTip><ToolTip x:Name="TtExportPdf"/></Button.ToolTip>
                    </Button>
                    <Button x:Name="BtnPressure"
                            Style="{StaticResource IconButton}"
                            Background="{DynamicResource HeaderButtonBrush}"
                            Content="🩺" FontSize="18"
                            Margin="0,0,6,0"
                            Click="BtnPressure_Click">
                        <Button.ToolTip><ToolTip x:Name="TtPressure"/></Button.ToolTip>
                    </Button>
                    <Button x:Name="BtnReminders"
                            Style="{StaticResource IconButton}"
                            Background="{DynamicResource HeaderButtonBrush}"
                            FontSize="18"
                            Margin="0,0,6,0"
                            Click="BtnReminders_Click">
                        <Button.ToolTip><ToolTip x:Name="TtReminders"/></Button.ToolTip>
                    </Button>
                    <Button x:Name="BtnNotes"
                            Style="{StaticResource IconButton}"
                            Background="{DynamicResource HeaderButtonBrush}"
                            Content="📝" FontSize="18"
                            Margin="0,0,6,0"
                            Click="BtnNotes_Click">
                        <Button.ToolTip><ToolTip x:Name="TtNotes"/></Button.ToolTip>
                    </Button>
                    <Button x:Name="BtnDocuments"
                            Style="{StaticResource IconButton}"
                            Background="{DynamicResource HeaderButtonBrush}"
                            Content="📁" FontSize="18"
                            Margin="0,0,6,0"
                            Click="BtnDocuments_Click">
                        <Button.ToolTip><ToolTip x:Name="TtDocuments"/></Button.ToolTip>
                    </Button>
                    <Button x:Name="BtnSettings"
                            Style="{StaticResource IconButton}"
                            Background="{DynamicResource HeaderButtonBrush}"
                            Content="⚙" FontSize="18"
                            Click="BtnSettings_Click">
                        <Button.ToolTip><ToolTip x:Name="TtSettings"/></Button.ToolTip>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Вкладки ═══ -->
        <TabControl Grid.Row="1"
                    Background="Transparent"
                    BorderBrush="{DynamicResource BgCardBrush}"
                    BorderThickness="0,0,0,1">
            <TabItem x:Name="TabSchedule" Style="{StaticResource DarkTab}">
                <Border Background="{DynamicResource BgCardBrush}" Padding="14"
                        CornerRadius="0,10,10,10">
                    <views:ScheduleView x:Name="ScheduleViewControl" />
                </Border>
            </TabItem>
            <TabItem x:Name="TabHistory" Style="{StaticResource DarkTab}">
                <Border Background="{DynamicResource BgCardBrush}" Padding="14"
                        CornerRadius="0,10,10,10">
                    <views:HistoryView x:Name="HistoryViewControl" />
                </Border>
            </TabItem>
            <TabItem x:Name="TabFinance" Style="{StaticResource DarkTab}">
                <Border Background="{DynamicResource BgCardBrush}" Padding="14"
                        CornerRadius="0,10,10,10">
                    <views:FinanceView x:Name="FinanceViewControl" />
                </Border>
            </TabItem>
            <TabItem x:Name="TabForecast" Style="{StaticResource DarkTab}">
                <Border Background="{DynamicResource BgCardBrush}" Padding="14"
                        CornerRadius="0,10,10,10">
                    <views:ForecastView x:Name="ForecastViewControl" />
                </Border>
            </TabItem>
            <TabItem x:Name="TabAskAi" Style="{StaticResource DarkTab}">
                <Border Background="{DynamicResource BgCardBrush}" Padding="14"
                        CornerRadius="0,10,10,10">
                    <views:AskAiView x:Name="AskAiViewControl" />
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
